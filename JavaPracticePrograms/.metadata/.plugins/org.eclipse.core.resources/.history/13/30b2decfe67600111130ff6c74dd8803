package Map;

import java.util.HashMap;


public class MapExample1 {
	public static void main(String[] args) {
		HashMap<Integer,String> map=new HashMap<>();
		map.put(1, "Saquib");
		map.put(2,"Faisal");
		map.put(3,"Kaushik");
		map.put(4, "Jassi");
		
		System.out.println(map);
		
		map.remove(3);
		System.out.println(map);
		
		System.out.println(map.isEmpty());
		map.clear();
		System.out.println(map.isEmpty());
		System.out.println(map);
	}
}
